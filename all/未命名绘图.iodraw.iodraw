        <UserObject label="sequenceDiagram&#xa;    autonumber&#xa;    participant User as 用户&#xa;    participant HMI as HMI进程（Qt/QML）&#xa;    participant HMIObj as HMIEventReceiveApp&#xa;    participant IPC as MessageClient / IPC通道&#xa;    participant AI as AI APP进程&#xa;    participant Worker as Worker线程&#xa;    participant Obs as avm_obstacle_periodic_shot_thread&#xa;    participant Aibox as AIBox线程&#xa;    participant LLM as LLM模型&#xa;    participant Android as Android终端&#xa;&#xa;&#xa;    User-&gt;&gt;HMI: 在设置页面打开“车外不審者認識”&#xa;    HMI-&gt;&gt;HMIObj: QML 调用 sendHMIEvent(0x4007, [1])&#xa;    HMIObj-&gt;&gt;HMIObj: 打包协议：0x40 0x07 + data[0]=1&#xa;    HMIObj-&gt;&gt;IPC: m_client-&gt;sendMessage(command)&#xa;    IPC--&gt;&gt;AI: 通过 IPC/消息通道传输 0x4007&#xa;&#xa;&#xa;    AI-&gt;&gt;Worker: grpcClient线程收到消息，送入 worker 队列&#xa;    Worker-&gt;&gt;Worker: 解析 cmd = 0x4007&#xa;    alt data == 1&#xa;        Worker-&gt;&gt;Worker: set_avm_obstacle_cycle_enable(true)&#xa;        Worker-&gt;&gt;Worker: setAiCarPhoneHomeSec(true)&#xa;    else data == 0&#xa;        Worker-&gt;&gt;Worker: set_avm_obstacle_cycle_enable(false)&#xa;        Worker-&gt;&gt;Worker: clear_hmiAppInfo()&#xa;    end&#xa;&#xa;&#xa;    Worker--&gt;&gt;Obs: 打开/关闭车外周期抓拍检测&#xa;    Obs-&gt;&gt;Obs: 左右摄像头交替抓拍&#xa;    Obs-&gt;&gt;Aibox: aiBoxQueue.push(0x9006 + 图像)&#xa;    Aibox-&gt;&gt;Aibox: run_aiBox() 取消息&#xa;    Aibox-&gt;&gt;Aibox: 调用 avm_aiapp_SuspiciousPersonDetectCycle()&#xa;    Aibox-&gt;&gt;LLM: llm_get_suspicious_person_state(image)&#xa;    LLM--&gt;&gt;Aibox: 返回 JSON 判断是否可疑&#xa;    alt 检测到可疑人员&#xa;        Aibox-&gt;&gt;Aibox: sendToAndroid_3006(true, img, size)&#xa;    else 未检测到可疑人员&#xa;        Aibox-&gt;&gt;Aibox: sendToAndroid_3006(false, nullptr, 0)&#xa;    end&#xa;    Aibox-&gt;&gt;Worker: worker_to_grpcClient.push(msg)&#xa;    Worker-&gt;&gt;IPC: 通过 grpcClient线程发出&#xa;    IPC--&gt;&gt;Android: 发送 0x3006 告警消息" link="sequenceDiagram&#xa;    autonumber&#xa;    participant User as 用户&#xa;    participant HMI as HMI进程（Qt/QML）&#xa;    participant HMIObj as HMIEventReceiveApp&#xa;    participant IPC as MessageClient / IPC通道&#xa;    participant AI as AI APP进程&#xa;    participant Worker as Worker线程&#xa;    participant Obs as avm_obstacle_periodic_shot_thread&#xa;    participant Aibox as AIBox线程&#xa;    participant LLM as LLM模型&#xa;    participant Android as Android终端&#xa;&#xa;&#xa;    User-&gt;&gt;HMI: 在设置页面打开“车外不審者認識”&#xa;    HMI-&gt;&gt;HMIObj: QML 调用 sendHMIEvent(0x4007, [1])&#xa;    HMIObj-&gt;&gt;HMIObj: 打包协议：0x40 0x07 + data[0]=1&#xa;    HMIObj-&gt;&gt;IPC: m_client-&gt;sendMessage(command)&#xa;    IPC--&gt;&gt;AI: 通过 IPC/消息通道传输 0x4007&#xa;&#xa;&#xa;    AI-&gt;&gt;Worker: grpcClient线程收到消息，送入 worker 队列&#xa;    Worker-&gt;&gt;Worker: 解析 cmd = 0x4007&#xa;    alt data == 1&#xa;        Worker-&gt;&gt;Worker: set_avm_obstacle_cycle_enable(true)&#xa;        Worker-&gt;&gt;Worker: setAiCarPhoneHomeSec(true)&#xa;    else data == 0&#xa;        Worker-&gt;&gt;Worker: set_avm_obstacle_cycle_enable(false)&#xa;        Worker-&gt;&gt;Worker: clear_hmiAppInfo()&#xa;    end&#xa;&#xa;&#xa;    Worker--&gt;&gt;Obs: 打开/关闭车外周期抓拍检测&#xa;    Obs-&gt;&gt;Obs: 左右摄像头交替抓拍&#xa;    Obs-&gt;&gt;Aibox: aiBoxQueue.push(0x9006 + 图像)&#xa;    Aibox-&gt;&gt;Aibox: run_aiBox() 取消息&#xa;    Aibox-&gt;&gt;Aibox: 调用 avm_aiapp_SuspiciousPersonDetectCycle()&#xa;    Aibox-&gt;&gt;LLM: llm_get_suspicious_person_state(image)&#xa;    LLM--&gt;&gt;Aibox: 返回 JSON 判断是否可疑&#xa;    alt 检测到可疑人员&#xa;        Aibox-&gt;&gt;Aibox: sendToAndroid_3006(true, img, size)&#xa;    else 未检测到可疑人员&#xa;        Aibox-&gt;&gt;Aibox: sendToAndroid_3006(false, nullptr, 0)&#xa;    end&#xa;    Aibox-&gt;&gt;Worker: worker_to_grpcClient.push(msg)&#xa;    Worker-&gt;&gt;IPC: 通过 grpcClient线程发出&#xa;    IPC--&gt;&gt;Android: 发送 0x3006 告警消息" id="c5dkT5dbg2BlWebvFBzi-64">
          <mxCell style="text;whiteSpace=wrap;" vertex="1" parent="1">
            <mxGeometry x="920" y="200" width="390" height="700" as="geometry" />
          </mxCell>
        </UserObject>
